{
  "name": "bertinis-vault",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "node ./scripts/dev-workspace.mjs",
    "api:dev": "corepack pnpm --filter @bertinis-vault/api dev",
    "web:dev": "corepack pnpm --filter @bertinis-vault/web dev",
    "web:typecheck": "corepack pnpm --filter @bertinis-vault/web typecheck",
    "web:build": "corepack pnpm --filter @bertinis-vault/web build",
    "web:verify": "corepack pnpm --filter @bertinis-vault/web typecheck && corepack pnpm --filter @bertinis-vault/web build",
    "web:preview": "corepack pnpm --filter @bertinis-vault/web preview",
    "foundry:fixtures": "corepack pnpm --filter @bertinis-vault/foundry-exporter build && node ./scripts/export-foundry-validation-fixtures.mjs",
    "foundry:verify": "corepack pnpm foundry:fixtures && node ./scripts/verify-foundry-validation-baseline.mjs",
    "mvp:verify": "corepack pnpm verify:env && corepack pnpm web:verify && corepack pnpm --filter @bertinis-vault/api test && corepack pnpm --filter @bertinis-vault/domain test && corepack pnpm foundry:verify && node ./scripts/build-mvp-release-status.mjs",
    "release:ready": "node ./scripts/check-release-readiness.mjs",
    "verify:env": "node ./scripts/verify-env.mjs",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test"
  }
}
