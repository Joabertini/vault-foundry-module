{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@bertinis-vault/contracts": ["packages/contracts/src/index.ts"],
      "@bertinis-vault/data-engine": ["packages/data-engine/src/index.ts"],
      "@bertinis-vault/domain": ["packages/domain/src/index.ts"],
      "@bertinis-vault/foundry-exporter": ["packages/foundry-exporter/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  }
}
